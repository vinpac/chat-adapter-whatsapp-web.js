{
  "name": "chat-adapter-whatsapp-web.js",
  "version": "0.0.1",
  "description": "WhatsApp adapter for chat using whatsapp-web.js",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chat-adapter/shared": "^4.19.0",
    "chat": "^4.19.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat",
    "whatsapp",
    "whatsapp-web.js",
    "bot",
    "adapter"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.30.3"
}
